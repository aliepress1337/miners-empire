generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameState {
  id            String   @id
  gameStartedAt DateTime
  gameEndsAt    DateTime
  rewardPool    Int      @default(20)
  finalizedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Player {
  id              String   @id
  telegramId      String?  @unique
  username        String?
  firstName       String?
  balance         Float    @default(0)
  clickProfit     Float    @default(1)
  hourlyProfit    Float    @default(0)
  smallBoneLevel  Int      @default(0)
  bigBoneLevel    Int      @default(0)
  autoFarm1Level  Int      @default(0)
  autoFarm2Level  Int      @default(0)
  upgradeLevels   Json?
  level10UnlockStep Int @default(0)
  level10AnimationCompleted Boolean @default(false)
  unlockedCoinSkins Json?
  selectedCoinSkin Int?
  afkFullFarmUnlocked Boolean @default(false)
  unluckyUntil DateTime?
  bannedAt DateTime?
  banReason String?

  referrerId      String?
  referralBonusClaimed Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrer Player?  @relation("PlayerReferrals", fields: [referrerId], references: [id])
  referrals Player[] @relation("PlayerReferrals")

  finalReward FinalReward?
}

model FinalReward {
  id            String   @id
  playerId      String   @unique
  telegramId    String?
  username      String?
  firstName     String?
  finalBalance  Float
  sharePercent  Float
  rewardAmount  Float
  promoCode     String
  finalizedAt   DateTime

  player Player @relation(fields: [playerId], references: [id])
}